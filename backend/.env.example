# ============================================================
# SAHIL VOTING HUB — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=production

# MongoDB — replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/sahil_hub?retryWrites=true&w=majority

# JWT Secrets — use long random strings (min 64 chars)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_use_random_64_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_also_change_this_random_64_chars

# Admin credentials — change before deployment
ADMIN_USERNAME=sahil_admin
ADMIN_PASSWORD=Admin@Sahil2024!
ADMIN_NAME=Sahil Admin

# CORS — your frontend domain (no trailing slash)
FRONTEND_URL=https://your-frontend-domain.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
